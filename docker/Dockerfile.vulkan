# llama.cpp built with Vulkan, suitable for AMD/Intel/NVIDIA via the Vulkan
# driver shipped on the host. The container only needs /dev/dri passed in.
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake git \
    libvulkan-dev spirv-headers vulkan-tools mesa-vulkan-drivers glslc \
    ca-certificates curl \
 && rm -rf /var/lib/apt/lists/*

# Pinned llama.cpp commit. Bumping this is a release-level decision so
# every user gets the same image. To bump: pick a known-good commit
# (Qwen3 embedders are sensitive to GGUF parser changes), update both
# Dockerfile.vulkan and Dockerfile.cpu in lockstep, bump hydra-llm
# version, rebuild, ship.
ARG LLAMA_CPP_REF=e43431b38115
WORKDIR /src
RUN git clone https://github.com/ggml-org/llama.cpp.git . \
 && git checkout "$LLAMA_CPP_REF" \
 && cmake -B build -DGGML_VULKAN=1 -DCMAKE_BUILD_TYPE=Release \
 && cmake --build build --config Release -j "$(nproc)" \
 && mkdir -p /opt/llama \
 && cp -r build/bin/. /opt/llama/ \
 && rm -rf /src

ENV PATH=/opt/llama:/usr/local/bin:$PATH \
    LD_LIBRARY_PATH=/opt/llama \
    GGML_VULKAN=1

# Carry the llama.cpp ref the image was built from so the deb postinst can
# compare it against the Dockerfile shipped with the *currently-installed*
# hydra-llm and rebuild on mismatch (upgrade or downgrade).
LABEL llama_cpp_ref="${LLAMA_CPP_REF}"

EXPOSE 8081
ENTRYPOINT ["llama-server"]
CMD ["--help"]
